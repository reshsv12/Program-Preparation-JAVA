import java.util.*;
public class Main
{
	public static void main(String[] args) {
		int i=0,j=1,k=1;
		System.out.print("Enter the number of row:");
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		for (i = 1; i<=n; i++){
		    for( j = 1; j<=i; j++){
		        System.out.print(k + " ");
		        k++;
		    }
		    System.out.println();
		}
	}
}
